---
import MainLayout from '../layouts/MainLayout.astro';

const heroImage = "https://imagedelivery.net/-sPAUAWeA405NiWJ0SNIQA/43f3f375-93e2-40c4-622c-10f903a25900/public";
const contactEmail = "sales@desertrich.com";
const subjectLine = "Acquisition Inquiry — azwax.ing";
const mailtoLink = `mailto:${contactEmail}?subject=${encodeURIComponent(subjectLine)}`;

const whyCards = [
  {
    icon: "fa-map-marked",
    title: "Statewide Arizona Authority",
    desc: "\"AZ\" instantly signals the entire Grand Canyon State — from the dominant Phoenix metro to Scottsdale, Tucson, and growing communities statewide.",
  },
  {
    icon: "fa-bolt",
    title: "Dynamic .ing TLD",
    desc: "The modern, verb-driven extension evokes action and transformation — perfect for \"waxing,\" \"smoothing,\" and \"confidence building.\" Stands out in a crowded .com world.",
  },
  {
    icon: "fa-search",
    title: "High-Intent Keywords",
    desc: "Combines the powerful \"wax\" keyword with clear geographic intent. Aligns naturally with searches for Arizona waxing, body waxing AZ, and professional hair removal.",
  },
  {
    icon: "fa-expand",
    title: "Exceptionally Versatile",
    desc: "Ideal foundation for a flagship salon, multi-location group, mobile service, statewide booking platform, esthetician network, premium product line, or training academy.",
  },
  {
    icon: "fa-shield-halved",
    title: "Defensible Brand Moat",
    desc: "Short, memorable, ownable, and scarce. True one-of-a-kind digital real estate that competitors cannot easily replicate or outrank.",
  },
  {
    icon: "fa-rocket",
    title: "Instant Credibility & SEO Lift",
    desc: "Premium domains with clear geo + service alignment deliver faster trust signals and stronger local search performance from day one.",
  },
];

const useCases = [
  {
    icon: "fa-store",
    title: "Flagship Salon or Multi-Location Group",
    desc: "Establish immediate authority as Arizona's premier waxing destination with a name that works across Phoenix, Scottsdale, and beyond.",
  },
  {
    icon: "fa-mobile-screen-button",
    title: "Mobile or Concierge Waxing Service",
    desc: "Perfect for on-demand, in-home, or event-based services. Short, memorable, and instantly communicates professionalism statewide.",
  },
  {
    icon: "fa-calendar-check",
    title: "Statewide Booking Platform or Directory",
    desc: "Become the trusted hub connecting clients with vetted estheticians and salons across Arizona.",
  },
  {
    icon: "fa-graduation-cap",
    title: "Waxing Academy or Training Brand",
    desc: "Position as the educational leader for Arizona estheticians with a modern, ownable brand name.",
  },
  {
    icon: "fa-flask",
    title: "Premium Product Line or Aftercare",
    desc: "Launch a signature line of hard waxes, oils, and aftercare products under a powerful, Arizona-rooted brand.",
  },
  {
    icon: "fa-globe",
    title: "National or Franchise Concept",
    desc: "Use the strong Arizona flagship identity as the foundation for regional or national expansion in the beauty services space.",
  },
];
---

<MainLayout>
  <!-- ============================================ -->
  <!-- NAVIGATION                                   -->
  <!-- ============================================ -->
  <nav class="bg-white/95 backdrop-blur-md border-b border-desert-border sticky top-0 z-50">
    <div class="max-w-7xl mx-auto px-6">
      <div class="flex items-center justify-between h-20">
        <div class="flex items-center gap-x-3">
          <div class="flex items-center gap-x-2">
            <div class="w-9 h-9 bg-desert-terracotta rounded-xl flex items-center justify-center">
              <span class="text-white text-2xl font-bold tracking-tighter">AZ</span>
            </div>
            <div>
              <span class="font-semibold text-2xl tracking-tight">azwax</span>
              <span class="font-semibold text-2xl tracking-tight text-desert-terracotta">.ing</span>
            </div>
          </div>
        </div>

        <div class="flex items-center gap-x-4">
          <a href="#why" class="hidden md:block px-4 py-2 text-sm font-medium text-desert-sage hover:text-desert-charcoal transition-colors">Why This Domain</a>
          <a href="#market" class="hidden md:block px-4 py-2 text-sm font-medium text-desert-sage hover:text-desert-charcoal transition-colors">The Market</a>
          <a href="#use-cases" class="hidden md:block px-4 py-2 text-sm font-medium text-desert-sage hover:text-desert-charcoal transition-colors">Use Cases</a>

          <a href="#acquire"
             class="inline-flex items-center justify-center px-6 py-2.5 bg-desert-terracotta hover:bg-desert-terracotta-dark text-white text-sm font-semibold rounded-2xl transition-all active:scale-[0.985]">
            Make an Offer
          </a>
        </div>
      </div>
    </div>
  </nav>

  <!-- ============================================ -->
  <!-- HERO                                         -->
  <!-- ============================================ -->
  <header class="relative overflow-hidden">
    <!-- Hero image (Cloudflare Images CDN) -->
    <div class="absolute inset-0">
      <img
        src={heroImage}
        alt="Arizona waxing and beauty services — premium domain background"
        class="w-full h-full object-cover opacity-50 sm:opacity-60"
        loading="eager"
        fetchpriority="high"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-desert-sand/90 via-desert-sand/45 to-desert-sand/15"></div>
    </div>

    <div class="relative z-10 max-w-5xl mx-auto px-6 pt-16 pb-20 md:pt-20 md:pb-24 text-center">
      <!-- Badge -->
      <div class="inline-flex items-center gap-x-2 mb-6">
        <div class="modern-pill flex items-center gap-x-1.5">
          <i class="fa-solid fa-gem text-xs"></i>
          <span>PREMIUM • RARE • ONE-OF-A-KIND</span>
        </div>
      </div>

      <h1 class="text-[4.5rem] leading-none font-extrabold tracking-[-0.04em] text-desert-charcoal mb-4 font-serif">
        azwax.ing
      </h1>

      <p class="max-w-2xl mx-auto text-2xl md:text-3xl font-semibold tracking-tight text-desert-sage mb-6">
        Arizona's definitive domain for<br class="hidden md:block" /> professional waxing &amp; hair removal.
      </p>

      <p class="max-w-lg mx-auto text-lg text-desert-warm mb-10">
        The modern, action-oriented .ing domain that captures the entire Arizona beauty and grooming market.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="#acquire"
           class="group inline-flex items-center justify-center gap-x-3 w-full sm:w-auto px-9 py-4 cta-primary text-white font-semibold text-lg rounded-3xl transition-all active:scale-[0.985] shadow-lg shadow-desert-terracotta/20">
          <span>Inquire to Acquire</span>
          <i class="fa-solid fa-arrow-right group-hover:translate-x-0.5 transition-transform"></i>
        </a>

        <a href="#why"
           class="inline-flex items-center justify-center w-full sm:w-auto px-8 py-4 cta-secondary text-desert-sage font-semibold text-lg rounded-3xl transition-all">
          Explore the Opportunity
        </a>
      </div>

      <div class="mt-8 flex items-center justify-center gap-x-6 text-sm text-desert-muted">
        <div class="flex items-center gap-x-1.5">
          <i class="fa-solid fa-check text-desert-terracotta"></i>
          <span>Instant brand authority</span>
        </div>
        <div class="flex items-center gap-x-1.5">
          <i class="fa-solid fa-check text-desert-terracotta"></i>
          <span>Statewide reach</span>
        </div>
      </div>
    </div>

    <!-- Subtle decorative element -->
    <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[800px] h-[1px] bg-gradient-to-r from-transparent via-desert-line to-transparent"></div>
  </header>

  <!-- ============================================ -->
  <!-- WHY THIS DOMAIN                              -->
  <!-- ============================================ -->
  <section id="why" class="max-w-7xl mx-auto px-6 py-16 md:py-20 border-t border-desert-border">
    <div class="text-center mb-12">
      <div class="inline-block modern-pill mb-3">STRATEGIC ADVANTAGE</div>
      <h2 class="text-[2.25rem] leading-[2.5rem] font-bold tracking-tight text-desert-charcoal font-serif">
        Why azwax.ing is a rare premium asset
      </h2>
      <p class="mt-4 max-w-md mx-auto text-desert-warm">
        A perfect convergence of geography, service keywords, and modern branding.
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {whyCards.map((card) => (
        <div class="value-card bg-white border border-desert-border rounded-3xl p-8">
          <div class="w-12 h-12 bg-desert-sand rounded-2xl flex items-center justify-center mb-6">
            <i class={`fa-solid ${card.icon} text-desert-terracotta text-2xl`}></i>
          </div>
          <h3 class="font-semibold text-xl tracking-tight mb-3">{card.title}</h3>
          <p class="text-desert-warm leading-relaxed">{card.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ============================================ -->
  <!-- MARKET OPPORTUNITY                           -->
  <!-- ============================================ -->
  <section id="market" class="bg-white border-y border-desert-border">
    <div class="max-w-5xl mx-auto px-6 py-16 md:py-20">
      <div class="grid md:grid-cols-12 gap-x-12 items-center">
        <div class="md:col-span-7">
          <div class="modern-pill mb-4 inline-block">GROWING MARKET</div>
          <h2 class="text-[2.25rem] leading-[2.5rem] font-bold tracking-tight text-desert-charcoal mb-6 font-serif">
            Arizona's thriving beauty &amp; grooming economy
          </h2>

          <div class="prose prose-lg text-desert-sage">
            <p class="mb-4">Arizona combines rapid population growth, strong tourism, and an active desert lifestyle that fuels consistent demand for professional, hygienic, and confidence-boosting hair removal services.</p>

            <p>The Phoenix metropolitan area — the state's dominant market — continues to expand, while Scottsdale's luxury positioning and Tucson's growing communities add further depth. Warm climate, fitness culture, and year-round visitors create sustained need for expert waxing across body, facial, and specialized treatments.</p>
          </div>
        </div>

        <div class="md:col-span-5 mt-10 md:mt-0">
          <div class="bg-desert-sand rounded-3xl p-8 border border-desert-border">
            <div class="space-y-6">
              <div>
                <div class="flex justify-between items-baseline mb-1">
                  <span class="text-sm font-medium text-desert-muted">U.S. Hair Removal Market</span>
                </div>
                <div class="flex items-baseline gap-x-2">
                  <span class="text-4xl font-semibold tracking-tighter stat-number">~$416M</span>
                  <span class="text-sm text-desert-terracotta font-medium">2025</span>
                </div>
                <div class="text-xs text-desert-muted">Growing at ~6% CAGR through 2034</div>
              </div>

              <div class="pt-4 border-t border-desert-line">
                <div class="text-sm font-medium text-desert-muted mb-2">Key Drivers in Arizona</div>
                <ul class="space-y-2 text-sm">
                  <li class="flex items-start gap-x-2"><i class="fa-solid fa-check text-desert-terracotta mt-1 text-xs"></i> <span>Fast-growing population &amp; in-migration</span></li>
                  <li class="flex items-start gap-x-2"><i class="fa-solid fa-check text-desert-terracotta mt-1 text-xs"></i> <span>Strong tourism &amp; hospitality sector</span></li>
                  <li class="flex items-start gap-x-2"><i class="fa-solid fa-check text-desert-terracotta mt-1 text-xs"></i> <span>Active outdoor lifestyle &amp; warm climate</span></li>
                  <li class="flex items-start gap-x-2"><i class="fa-solid fa-check text-desert-terracotta mt-1 text-xs"></i> <span>Rising male grooming demand</span></li>
                </ul>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- USE CASES                                    -->
  <!-- ============================================ -->
  <section id="use-cases" class="max-w-7xl mx-auto px-6 py-16 md:py-20">
    <div class="text-center mb-12">
      <div class="modern-pill mb-3">ENDLESS POSSIBILITIES</div>
      <h2 class="text-[2.25rem] leading-[2.5rem] font-bold tracking-tight text-desert-charcoal font-serif">
        Built for ambitious brands and operators
      </h2>
      <p class="mt-3 max-w-md mx-auto text-desert-warm">
        azwax.ing scales with your vision — from single-location excellence to statewide leadership.
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {useCases.map((uc) => (
        <div class="group bg-white border border-desert-border hover:border-desert-terracotta/30 rounded-3xl p-8 transition-all">
          <div class="flex items-center gap-x-4 mb-5">
            <div class="text-desert-terracotta"><i class={`fa-solid ${uc.icon} text-2xl`}></i></div>
            <h4 class="font-semibold text-lg">{uc.title}</h4>
          </div>
          <p class="text-desert-warm">{uc.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ============================================ -->
  <!-- FINAL ACQUISITION CTA                        -->
  <!-- ============================================ -->
  <section id="acquire" class="bg-desert-charcoal text-white">
    <div class="max-w-4xl mx-auto px-6 py-20 text-center">
      <div class="max-w-2xl mx-auto">
        <div class="inline-block px-4 py-1 bg-white/10 rounded-full text-sm font-medium tracking-wider mb-6">
          RARE DIGITAL ASSET
        </div>

        <h2 class="text-5xl md:text-6xl font-semibold tracking-tighter mb-6 font-serif">
          Own the name that defines<br />Arizona waxing.
        </h2>

        <p class="text-xl text-white/70 max-w-md mx-auto mb-10">
          azwax.ing is a high-value, one-of-a-kind premium domain for qualified buyers seeking immediate market authority and long-term brand equity.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href={mailtoLink}
             class="inline-flex items-center justify-center gap-x-3 px-10 py-4 bg-white text-desert-charcoal hover:bg-desert-sand font-semibold text-lg rounded-3xl transition-all active:scale-[0.985]">
            <span>Make an Offer</span>
            <i class="fa-solid fa-envelope"></i>
          </a>

          <button onclick="copyEmail()"
                  class="inline-flex items-center justify-center gap-x-3 px-8 py-4 border border-white/30 hover:bg-white/5 font-medium text-lg rounded-3xl transition-all">
            <span>Copy Contact Email</span>
          </button>
        </div>

        <p class="mt-8 text-sm text-white/50">
          Serious inquiries only. Flexible acquisition structures available for the right buyer.
        </p>
      </div>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- STICKY MOBILE CTA                            -->
  <!-- ============================================ -->
  <div class="sticky-cta fixed bottom-0 left-0 right-0 z-50 sm:hidden px-4 py-3">
    <a href={mailtoLink}
       class="cta-primary w-full py-3 rounded-full text-white font-semibold text-sm flex items-center justify-center gap-2">
      INQUIRE TO ACQUIRE — OWN THIS DOMAIN
    </a>
  </div>

  <!-- ============================================ -->
  <!-- FOOTER                                       -->
  <!-- ============================================ -->
  <footer class="bg-white border-t border-desert-border">
    <div class="max-w-7xl mx-auto px-6 py-16">
      <!-- Sophisticated Footer CTA -->
      <div class="max-w-3xl mx-auto text-center mb-12">
        <div class="inline-block modern-pill mb-4">DOMAIN AVAILABLE FOR ACQUISITION</div>
        <h3 class="text-2xl sm:text-3xl font-bold text-desert-charcoal mb-4 font-serif">
          Secure the definitive digital brand for Arizona waxing.
        </h3>
        <p class="text-desert-warm text-sm sm:text-base mb-8 max-w-lg mx-auto leading-relaxed">
          azwax.ing is a rare, one-of-a-kind premium .ing domain strategically positioned for the growing Arizona beauty and grooming market. Qualified buyers are invited to inquire directly.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
          <a href={mailtoLink}
             class="inline-flex items-center justify-center gap-x-3 px-8 py-3.5 bg-desert-terracotta hover:bg-desert-terracotta-dark text-white font-semibold rounded-2xl transition-all active:scale-[0.985] shadow-lg shadow-desert-terracotta/20">
            <i class="fa-solid fa-envelope"></i>
            <span>{contactEmail}</span>
          </a>
          <button onclick="copyEmail()"
                  class="inline-flex items-center justify-center gap-x-2 px-6 py-3.5 border border-desert-line hover:border-desert-terracotta hover:bg-desert-terracotta/5 text-desert-charcoal font-medium rounded-2xl transition-all text-sm">
            <i class="fa-regular fa-copy"></i>
            <span>Copy Email</span>
          </button>
        </div>
      </div>

      <!-- Divider -->
      <div class="border-t border-desert-border pt-8">
        <!-- Disclaimer -->
        <div class="max-w-3xl mx-auto text-center">
          <p class="text-[11px] sm:text-xs text-desert-muted leading-relaxed mb-4">
            This website is for demonstration and informational purposes only. It does not constitute an offer of services,
            a commitment to deploy, or a guarantee of outcomes. All statistics, projections, and references to specific
            technologies are based on publicly available information as of the date shown and are subject to change.
          </p>
          <p class="text-[11px] sm:text-xs text-desert-line">
            &copy; {new Date().getFullYear()} azwax.ing — Built with Astro + Cloudflare Pages
          </p>
        </div>
      </div>
    </div>
  </footer>
</MainLayout>

<!-- Font Awesome (loaded once, below fold) -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

<script>
  function copyEmail() {
    const email = 'sales@desertrich.com';
    navigator.clipboard.writeText(email).then(() => {
      const btns = document.querySelectorAll('button');
      btns.forEach(btn => {
        if (btn.innerText.includes('Copy')) {
          const original = btn.innerHTML;
          btn.innerHTML = `<span>✓ Copied!</span>`;
          setTimeout(() => {
            btn.innerHTML = original;
          }, 2200);
        }
      });
    }).catch(() => {
      window.location.href = `mailto:${email}`;
    });
  }

  // Subtle scroll effect on nav
  window.addEventListener('scroll', () => {
    const nav = document.querySelector('nav');
    if (window.scrollY > 20) {
      nav?.classList.add('nav-scrolled', 'bg-white/95');
    } else {
      nav?.classList.remove('nav-scrolled');
    }
  });

  console.log('%c[azwax.ing] Premium landing page ready. Astro + Cloudflare Pages.', 'color:#B85C38');
</script>
